[Unit]
Description=voluntariat.opensource.cat

[Service]
Type=simple
Restart=always
#EnvironmentFile=/opensource.cat/voluntariat-el-tingladu/.env
WorkingDirectory=/opensource.cat/voluntariat-el-tingladu/
ExecStart=/opensource.cat/voluntariat-el-tingladu/.venv/bin/python3 -m gunicorn -w 4 -b 127.0.0.1:8080 'voluntariat_app:create_app()'
#TimeoutStartSec=600

[Install]
WantedBy=multi-user.target
